{
  "id": "general",
  "name": "常规",
  "schema": {
    "general": {
      "text": "常规",
      "type": "section"
    },
    "general.working-file": {
      "text": "自动加载工作文件",
      "description": "启动时自动加载最新的工作文件",
      "type": "check",
      "default": false
    },
    "general.auto-backup": {
      "text": "自动备份",
      "description": "自动备份工作模型",
      "type": "check",
      "default": true
    },
    "theme": {
      "text": "界面主题",
      "type": "section"
    },
    "theme.default": {
      "text": "默认主题",
      "description": "界面默认主题",
      "type": "dropdown",
      "options": [
        { "value": "dark", "text": "深色主题" },
        { "value": "light", "text": "浅色主题" }
      ],
      "default": "dark"
    },
    "view": {
      "text": "默认视图样式",
      "type": "section"
    },
    "view.font": {
      "text": "字体",
      "description": "视图元素的默认字体",
      "type": "font",
      "default": "Arial"
    },
    "view.fontSize": {
      "text": "字号",
      "description": "视图元素的默认字号",
      "type": "combo",
      "options": [
        { "value": 8,  "text": "8"  },
        { "value": 9,  "text": "9"  },
        { "value": 10, "text": "10" },
        { "value": 11, "text": "11" },
        { "value": 12, "text": "12" },
        { "value": 13, "text": "13" },
        { "value": 14, "text": "14" },
        { "value": 16, "text": "16" },
        { "value": 20, "text": "20" },
        { "value": 24, "text": "24" },
        { "value": 28, "text": "28" },
        { "value": 32, "text": "32" }
      ],
      "default": 13
    },
    "view.fillColor": {
      "text": "填充颜色",
      "description": "视图元素的默认填充颜色",
      "type": "color",
      "default": "#ffffff"
    },
    "view.lineColor": {
      "text": "线条颜色",
      "description": "视图元素的默认字体颜色",
      "type": "color",
      "default": "#000000"
    },
    "view.fontColor": {
      "text": "字体颜色",
      "description": "视图元素的默认字体样式",
      "type": "color",
      "default": "#000000"
    },
    "view.lineStyle": {
      "text": "线条样式",
      "description": "边类型视图元素的默认线条样式",
      "type": "dropdown",
      "options": [
        { "value": 0, "text": "直线" },
        { "value": 1, "text": "斜线" },
        { "value": 2, "text": "圆角直线" },
        { "value": 3, "text": "曲线" }
      ],
      "default": 1
