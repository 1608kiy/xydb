      "text": "显示阴影",
      "description": "视图元素的默认显示阴影",
      "type": "check",
      "default": true
    },
    "diagramEditor": {
      "text": "图表编辑器",
      "type": "section"
    },
    "diagramEditor.showGrid": {
      "text": "显示网格",
      "description": "在图表编辑器上显示网格",
      "type": "check",
      "default": true
    },
    "diagramEditor.snapToGrid": {
      "text": "对齐网格",
      "description": "在图表编辑器上对齐网格",
      "type": "check",
      "default": true
    },
    "diagramEditor.gridSize": {
      "text": "网格尺寸",
      "description": "默认网格尺寸",
      "type": "combo",
      "options": [
        { "value": 2,  "text": "2"  },
        { "value": 4,  "text": "4"  },
        { "value": 6,  "text": "6" },
        { "value": 8,  "text": "8" },
        { "value": 10, "text": "10" },
        { "value": 12, "text": "12" },
        { "value": 14, "text": "14" },
        { "value": 16, "text": "16" },
        { "value": 18, "text": "18" },
        { "value": 20, "text": "20" }
      ],
      "default": 8
