    "diagramEditor.backgroundColor": {
      "text": "背景颜色",
      "description": "图表编辑器的背景颜色",
      "type": "color",
      "default": "#ffffff"
    },
    "validation": {
      "text": "验证",
      "type": "section"
    },
    "validation.validateModel": {
      "text": "验证模型",
      "description": "打开或保存文件时异步验证模型",
      "type": "check",
      "default": true
    },
    "checkUpdate": {
      "text": "检查更新",
      "type": "section"
    },
    "checkUpdate.checkUpdateOnStart": {
      "text": "启动时检查更新",
      "description": "启动应用时检查更新",
      "type": "check",
      "default": true
    }
  }
}
