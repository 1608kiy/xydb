        "command-arg": { "container-views": ["WFFrameView", "WFPanelView"] }
      },
      {
        "label": "图像", 
        "id": "WFImage", 
        "icon": "icon-WFImage",
        "rubberband": "rect",
        "command-arg": { "container-views": ["WFFrameView", "WFPanelView"] }
      },
      {
        "label": "分隔符", 
        "id": "WFSeparator", 
        "icon": "icon-WFSeparator",
        "rubberband": "rect",
        "command-arg": { "container-views": ["WFFrameView", "WFPanelView"] }
      },
      {
        "label": "头像", 
        "id": "WFAvatar", 
        "icon": "icon-WFAvatar",
        "rubberband": "rect",
        "command-arg": { "container-views": ["WFFrameView", "WFPanelView"] }
      },
      {
        "label": "滑块", 
        "id": "WFSlider", 
        "icon": "icon-WFSlider",
        "rubberband": "rect",
        "command-arg": { "container-views": ["WFFrameView", "WFPanelView"] }
