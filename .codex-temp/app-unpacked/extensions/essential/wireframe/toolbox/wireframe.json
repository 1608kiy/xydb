      {
        "label": "选项卡", 
        "id": "WFTab", 
        "icon": "icon-WFTab",
        "rubberband": "rect",
        "command-arg": { "container-views": ["WFFrameView", "WFPanelView", "WFTabListView"] }
      },
      {
        "label": "输入框", 
        "id": "WFInput", 
        "icon": "icon-WFInput",
        "rubberband": "rect",
        "command-arg": { "container-views": ["WFFrameView", "WFPanelView"] }
      },
      {
        "label": "下拉框", 
        "id": "WFDropdown", 
        "icon": "icon-WFDropdown",
        "rubberband": "rect",
        "command-arg": { "container-views": ["WFFrameView", "WFPanelView"] }
